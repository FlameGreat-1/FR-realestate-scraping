# Real Estate Scraper - environment configuration
# Copy to .env and adjust as needed.

# --- Input / Output ---
INPUT_CSV=data/Test_case_realestate_scraping_50.csv
OUTPUT_DIR=output
LISTINGS_CSV_NAME=listings_consolidated.csv
ERROR_LOG_CSV_NAME=error_log.csv
DOMAIN_SUMMARY_CSV_NAME=domain_status_summary.csv
CHECKPOINT_FILE_NAME=.checkpoint.json
# JSON-on-disk geocode cache; only read/written when ENABLE_GEOCODING=true.
GEOCODE_CACHE_NAME=.geocode_cache.json

# --- Concurrency ---
DOMAIN_CONCURRENCY=12
PER_HOST_CONCURRENCY=4
LISTING_CONCURRENCY=24
BROWSER_CONCURRENCY=3

# --- Timeouts (seconds) ---
HTTP_PROBE_TIMEOUT=8
HTTP_FETCH_TIMEOUT=15
# 90s caps wall-clock at (jobs / workers) * 90; pipeline already
# escalates static -> dynamic -> per-page Playwright internally, so
# the previous 180s budget is no longer required.
DOMAIN_TIME_BUDGET=90
BROWSER_NAV_TIMEOUT=20

# --- Limits ---
MAX_LISTING_URLS_PER_DOMAIN=120
MAX_SEED_URLS_PER_DOMAIN=80
MAX_SITEMAP_DEPTH=2
# How many hub levels the seed-expansion BFS walks (0 disables hub
# expansion entirely; 2 is enough for homepage -> /biens -> page=2).
SEED_EXPANSION_DEPTH=2
# Hard cap on hub HTML fetches per domain so chatty pagination cannot
# eat the per-domain time budget.
MAX_HUB_PAGES_PER_DOMAIN=12

# --- Behaviour ---
VERIFY_TLS=false
FOLLOW_REDIRECTS=true
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
ACCEPT_LANGUAGE=fr-FR,fr;q=0.9,en;q=0.7
ENABLE_PLAYWRIGHT=true
# Coordinates enrichment via Nominatim. Cache-only pre-pass is always
# instant; cold lookups are bounded by GEOCODER_ENRICHMENT_BUDGET so
# a cold cache cannot blow the per-domain time budget. Set to false
# at production scale if a managed-quota geocoder is preferred.
ENABLE_GEOCODING=true
GEOCODER_USER_AGENT=realestate_scraper/1.0
GEOCODER_TIMEOUT=3
# Hard wall-clock cap (seconds) on the geocoder enrichment pass per
# domain. Only the cold-lookup phase is bounded; cache hits are not.
GEOCODER_ENRICHMENT_BUDGET=30

# --- Retries ---
# 1 retry covers transient socket / TLS errors; persistent failures
# escalate via the dynamic-extractor fallback path, not via retries.
HTTP_MAX_RETRIES=1
HTTP_RETRY_BACKOFF=0.5

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Resume ---
RESUME=true
