# Real Estate Scraper - environment configuration
# Copy to .env and adjust as needed.

# --- Input / Output ---
INPUT_CSV=data/Test_case_realestate_scraping_50.csv
OUTPUT_DIR=output
LISTINGS_CSV_NAME=listings_consolidated.csv
ERROR_LOG_CSV_NAME=error_log.csv
DOMAIN_SUMMARY_CSV_NAME=domain_status_summary.csv
CHECKPOINT_FILE_NAME=.checkpoint.json
# JSON-on-disk geocode cache; only read/written when ENABLE_GEOCODING=true.
GEOCODE_CACHE_NAME=.geocode_cache.json

# --- Concurrency ---
DOMAIN_CONCURRENCY=12
PER_HOST_CONCURRENCY=6
LISTING_CONCURRENCY=24
BROWSER_CONCURRENCY=4

# --- Timeouts (seconds) ---
HTTP_PROBE_TIMEOUT=6
HTTP_FETCH_TIMEOUT=10
# 120s covers fingerprint + discovery + detail fetching. Worst case
# detail phase: 120 URLs / 24 concurrent * 10s = 50s. Leaves headroom
# for slow hosts and Playwright escalation.
DOMAIN_TIME_BUDGET=120
BROWSER_NAV_TIMEOUT=15

# --- Limits ---
# 40 candidates fits within the domain budget: 40 / 6 per-host * 10s
# = 67s worst case. Ranking puts best URLs first.
MAX_LISTING_URLS_PER_DOMAIN=40
MAX_SEED_URLS_PER_DOMAIN=80
MAX_SITEMAP_DEPTH=2
# How many hub levels the seed-expansion BFS walks (0 disables hub
# expansion entirely; 2 is enough for homepage -> /biens -> page=2).
SEED_EXPANSION_DEPTH=2
# Hard cap on hub HTML fetches per domain so chatty pagination cannot
# eat the per-domain time budget.
MAX_HUB_PAGES_PER_DOMAIN=12
# Hard wall-clock cap (seconds) on processing one listing URL. A URL
# that does not yield within this budget is dropped silently; the
# other candidates continue. Aligned with HTTP_FETCH_TIMEOUT so a
# timed-out fetch is dropped immediately.
LISTING_TIME_BUDGET=10

# --- Behaviour ---
VERIFY_TLS=false
FOLLOW_REDIRECTS=true
USER_AGENT=Mozilla/5.0 (X11; Linux x86_64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/124.0.0.0 Safari/537.36
ACCEPT_LANGUAGE=fr-FR,fr;q=0.9,en;q=0.7
ENABLE_PLAYWRIGHT=true
# Coordinates enrichment via Nominatim. Runs as a SINGLE post-pass
# after all domains have finished scraping, never on the per-domain
# hot path. Cache-warm runs are effectively free; cold lookups are
# bounded by GEOCODER_POST_PASS_BUDGET below. Disable in production
# if a managed-quota geocoder is preferred.
ENABLE_GEOCODING=true
GEOCODER_USER_AGENT=realestate_scraper/1.0
GEOCODER_TIMEOUT=3
# Hard wall-clock cap (seconds) on the post-run geocoder pass.
# Listings whose coordinates were not resolved when the budget runs
# out keep an empty `coordinates` field. Partial coverage is
# preferable to an unbounded run.
GEOCODER_POST_PASS_BUDGET=60
# Deprecated: replaced by GEOCODER_POST_PASS_BUDGET. Kept here for
# backward compatibility; setting it has no effect.
GEOCODER_ENRICHMENT_BUDGET=0

# --- Retries ---
# 1 retry covers transient socket / TLS errors; persistent failures
# escalate via the dynamic-extractor fallback path, not via retries.
HTTP_MAX_RETRIES=1
HTTP_RETRY_BACKOFF=0.5

# --- Logging ---
LOG_LEVEL=INFO
LOG_JSON=false

# --- Resume ---
RESUME=true
